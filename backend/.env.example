# ── Gemini (Embeddings) ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── Mistral-7B GGUF (Local LLM) ──
MODEL_PATH=/absolute/path/to/mistral-7b-instruct-v0.2.Q4_K_M.gguf

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./chroma_db

# ── Data directory for textbook PDFs / TXTs ──
DATA_DIR=./data

# ── LLM Parameters ──
CONTEXT_WINDOW=4096
MAX_NEW_TOKENS=512

# ── Retrieval Parameters ──
TOP_K=3
